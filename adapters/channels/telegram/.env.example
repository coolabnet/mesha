# Telegram Channel Adapter — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to the repository.

# ── Required ───────────────────────────────────────────────────────────────────

# Bot token obtained from @BotFather on Telegram.
# Format: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=

# Comma-separated list of numeric Telegram user IDs that receive "maintainer"
# trust (Class A, B, and C operations permitted).
# Find your user ID by messaging @userinfobot on Telegram.
# Example: 123456789,987654321
TELEGRAM_MAINTAINER_IDS=

# Comma-separated list of numeric Telegram user IDs that receive
# "lead_maintainer" trust (may approve Class C and Class D operations).
# These users should also be listed in TELEGRAM_MAINTAINER_IDS.
# Example: 123456789
TELEGRAM_LEAD_MAINTAINER_IDS=

# ── Polling / Webhook ──────────────────────────────────────────────────────────

# Webhook URL for webhook mode. When set, the adapter registers this URL with
# Telegram and switches from polling to webhook push delivery.
# Must be a valid HTTPS URL reachable from the internet.
# Leave empty to use long-polling mode (recommended for local/offline setups).
TELEGRAM_WEBHOOK_URL=

# Polling interval in milliseconds between getUpdates calls.
# Only used in polling mode (when TELEGRAM_WEBHOOK_URL is empty).
# Default: 1000 ms. Minimum recommended: 500 ms.
TELEGRAM_POLL_INTERVAL_MS=1000

# ── Webhook server port ────────────────────────────────────────────────────────

# Port the local HTTP server listens on when TELEGRAM_WEBHOOK_URL is set.
# Only used in webhook mode. Must match the port Telegram can reach.
# Default: 8080
WEBHOOK_PORT=8080

# ── Operator endpoint ──────────────────────────────────────────────────────────

# URL of the community-ops-frontdesk operator API endpoint.
# The adapter forwards normalized message envelopes to this URL via HTTP POST.
# Default: http://localhost:3000
OPERATOR_ENDPOINT=http://localhost:3000
