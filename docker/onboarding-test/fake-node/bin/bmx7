#!/usr/bin/env sh
set -eu

if [ "$#" -lt 2 ] || [ "$1" != "-c" ]; then
    exit 1
fi

case "$2" in
  --links)
    cat /fixtures/bmx7.links.txt
    ;;
  --originators)
    cat /fixtures/bmx7.originators.txt
    ;;
  --interfaces)
    cat /fixtures/bmx7.interfaces.txt
    ;;
  *)
    exit 1
    ;;
esac
