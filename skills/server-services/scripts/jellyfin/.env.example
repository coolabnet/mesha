# Path on the host where Jellyfin configuration and metadata are stored.
# Defaults to ./data/jellyfin/config (relative to this recipe directory).
# Change to an absolute path if your media or data lives on a separate disk.
JELLYFIN_DATA_PATH=./data/jellyfin/config

# Path on the host where Jellyfin writes its transcoding cache.
JELLYFIN_CACHE_PATH=./data/jellyfin/cache

# Path on the host where your media library lives (mounted read-only).
# Point this to wherever educational videos, documentaries, etc. are stored.
# Example: /data/media
JELLYFIN_MEDIA_PATH=./data/media
