# Path inside the container where Kolibri stores its home directory.
# This is where channels, user data, and facility configuration are kept.
# Do not change this unless you know what you are doing — it must match
# the volume mount in docker-compose.yaml.
KOLIBRI_HOME=/kolibri

# Human-readable name of the learning facility shown in the Kolibri UI.
# Set this to the name of the school or community group using this instance.
# Example: "Escola Municipal Bairro Novo"
KOLIBRI_FACILITY_NAME=Comunidade

# Host path where Kolibri data is persisted (default: ./data/kolibri).
# Change to an absolute path if the data should live on a separate disk.
KOLIBRI_DATA_PATH=./data/kolibri
