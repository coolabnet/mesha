# Nextcloud admin account
# Created automatically on first startup.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-strong-password

# MariaDB root password (used by the database container only)
MYSQL_ROOT_PASSWORD=change-me-root-password

# Nextcloud database credentials
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-me-db-password

# Space-separated list of trusted domains/IPs for Nextcloud.
# The local domain and the server IP are the minimum required entries.
# Example: "nuvem.bairro.local 10.13.0.1"
NEXTCLOUD_TRUSTED_DOMAINS=nuvem.bairro.local 10.13.0.1
