# ---------------------------------------------------------------------------
# Prometheus + Grafana monitoring stack — environment variables
# Community Infrastructure Operator — server-services skill
#
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Replace ALL change-me-* placeholders with real values
#   3. Never commit .env to git — it is excluded by .gitignore
#
# See secrets/README.md for the approved secrets management approach.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Grafana admin credentials
# Used for the Grafana admin account (full dashboard management)
# Guest read-only access is enabled separately (GF_AUTH_ANONYMOUS_ENABLED=true)
# ---------------------------------------------------------------------------

# Grafana admin username (default UI login)
GF_ADMIN_USER=admin

# Grafana admin password — MUST be changed before first run
# Use a strong password: openssl rand -base64 20
GF_ADMIN_PASSWORD=change-me-grafana-admin-password

# Grafana secret key — used for session signing and cookie encryption
# Generate with: openssl rand -hex 32
GF_SECRET_KEY=change-me-grafana-secret-key-hex-32-chars
